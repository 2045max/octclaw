# OctClaw environment configuration
# Copy this file to ~/.octclaw/.env and fill in your values

# AI Provider API Keys (set at least one)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=...

# Channel tokens (optional)
# OCTCLAW_TELEGRAM_TOKEN=
# OCTCLAW_DISCORD_TOKEN=
# OCTCLAW_SLACK_TOKEN=
# OCTCLAW_SLACK_WEBHOOK_URL=
